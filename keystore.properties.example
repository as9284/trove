# Copy this file to keystore.properties (which is gitignored) and fill in your
# own values to build a signed release. Without it, `assembleRelease` produces an
# unsigned APK, which is fine for building from source.
#
# storeFile is the path to your keystore, relative to the repo root or absolute.
storeFile=trove-release.jks
storePassword=your-keystore-password
keyAlias=trove
keyPassword=your-key-password
